--练习1：查询EMP表中，各个部门的平均工资，保留一个小数点
SELECT emp.deptno, TRUNC(AVG(emp.sal), 1)
FROM EMP
GROUP BY emp.deptno


--练习2：执行以下建表语句，按照每10岁作为一个年龄段，统计各个年龄段的平均余额，平均余额保留两个小数点。
--建表语句---
--DROP TABLE USER622;
CREATE TABLE USER622(ID NUMBER --用户ID
                     ,AGE NUMBER  --用户年龄
                     ,DEPOSIT NUMBER(10,2) --用户余额
                     );
                     
INSERT INTO USER622 VALUES(1,21,5000);
INSERT INTO USER622 VALUES(2,29,450);
INSERT INTO USER622 VALUES(3,25,500);
INSERT INTO USER622 VALUES(4,36,600);
INSERT INTO USER622 VALUES(5,32,70);
INSERT INTO USER622 VALUES(6,63,960);
INSERT INTO USER622 VALUES(7,93,-960);
INSERT INTO USER622 VALUES(8,91,960.69);
COMMIT;
SELECT * FROM USER622 ORDER BY AGE;

SELECT AGE,TRUNC(AGE,-1)
FROM USER622;

--运算是聚合运算
--优先级是先拼接后算+号，所以需要括号
SELECT (TRUNC(AGE,-1) || '-' || (TRUNC(AGE,-1)+9)), TRUNC(AVG(USER622.DEPOSIT), 2)
FROM USER622
GROUP BY TRUNC(AGE,-1) -- 这样分组依然是按照年龄段分组
--GROUP BY (TRUNC(AGE,-1) || '-' || (TRUNC(AGE,-1)+9))
ORDER BY (TRUNC(AGE,-1) || '-' || (TRUNC(AGE,-1)+9));


