# ==========================================
#  数据库连接配置模板 (sql.env)
# ==========================================

# ---------- MySQL 上游配置 ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=123456
# 默认连接的业务库名（可选，如果不指定，SQL 中需带库名）
MYSQL_DB=mall

# 拼接后的 JDBC URL (供 Sqoop 使用)
# 注意：如果密码包含特殊字符，可能需要 URL Encode
MYSQL_JDBC="jdbc:mysql://${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DB}?useUnicode=true&characterEncoding=utf-8&useSSL=false"


# ================= 数据库配置 =================
#MYSQL_JDBC=jdbc:mysql://master:3306/mall?useSSL=false

MYSQL_TABLE=your_mysql_table




# ================= Hive 配置 =================
HIVE_DB=default
HIVE_DATABASE=mall2
HIVE_TABLE=your_hive_table


# ================= 路径 配置 =================
MALL_MODEL_DIR=mall_db